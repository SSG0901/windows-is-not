<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Window Example</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            padding-top: 100px;
        }

        button {
            padding: 12px 20px;
            font-size: 16px;
            cursor: pointer;
        }

        #result {
            margin-top: 25px;
            font-size: 20px;
        }
    </style>
</head>

<body>

    <h1>JavaScript Window Example</h1>

    <button onclick="checkWindow()">Check Window Size</button>

    <p id="result"></p>

    <script>
        function checkWindow() {
            const width = window.innerWidth;
            const height = window.innerHeight;

            document.getElementById("result").innerHTML =
                "Window width: " + width + "px<br>" +
                "Window height: " + height + "px";
        }
    </script>

</body>
</html>
